<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>title</key>
    <string>Amber</string>
    <key>items</key>
    <array>
        <dict>
            <key>cell</key>
            <string>PSGroupCell</string>
            <key>label</key>
            <string>Amber LED 模式</string>
            <key>footerText</key>
            <string>从控制中心点击手电筒图标可切换模式。默认=白色LED，Amber=琥珀色LED，All=全部LED。</string>
        </dict>
        <dict>
            <key>cell</key>
            <string>PSSegmentCell</string>
            <key>defaults</key>
            <string>com.apple.coremedia</string>
            <key>key</key>
            <string>PSLEDMode</string>
            <key>label</key>
            <string>LED 模式</string>
            <key>default</key>
            <integer>0</integer>
            <key>validValues</key>
            <array>
                <integer>0</integer>
                <integer>1</integer>
                <integer>2</integer>
            </array>
            <key>validTitles</key>
            <array>
                <string>默认</string>
                <string>Amber</string>
                <string>All</string>
            </array>
        </dict>
        <dict>
            <key>cell</key>
            <string>PSGroupCell</string>
            <key>label</key>
            <string>手电筒频闪</string>
            <key>footerText</key>
            <string>开启后手电筒将以设定的频率闪烁。SOS 模式会发送 SOS 求救信号 (... --- ...)。警告：频闪可能对光敏性癫痫患者造成不适。</string>
        </dict>
        <dict>
            <key>cell</key>
            <string>PSSwitchCell</string>
            <key>defaults</key>
            <string>com.ps.amber</string>
            <key>key</key>
            <string>PSStrobeEnabled</string>
            <key>label</key>
            <string>启用频闪</string>
            <key>default</key>
            <false/>
        </dict>
        <dict>
            <key>cell</key>
            <string>PSMultiValueCell</string>
            <key>defaults</key>
            <string>com.ps.amber</string>
            <key>key</key>
            <string>PSStrobePattern</string>
            <key>label</key>
            <string>闪烁模式</string>
            <key>default</key>
            <integer>0</integer>
            <key>validValues</key>
            <array>
                <integer>0</integer>
                <integer>1</integer>
            </array>
            <key>validTitles</key>
            <array>
                <string>连续闪烁</string>
                <string>SOS 求救信号</string>
            </array>
        </dict>
        <dict>
            <key>cell</key>
            <string>PSSliderCell</string>
            <key>defaults</key>
            <string>com.ps.amber</string>
            <key>key</key>
            <string>PSStrobeFrequency</string>
            <key>label</key>
            <string>频率 (Hz)</string>
            <key>default</key>
            <real>3</real>
            <key>min</key>
            <real>0.5</real>
            <key>max</key>
            <real>20</real>
            <key>minValue</key>
            <real>0.5</real>
            <key>maxValue</key>
            <real>20</real>
            <key>isSegmented</key>
            <false/>
            <key>showValue</key>
            <true/>
        </dict>
        <dict>
            <key>cell</key>
            <string>PSSliderCell</string>
            <key>defaults</key>
            <string>com.ps.amber</string>
            <key>key</key>
            <string>PSStrobeSOSCycles</string>
            <key>label</key>
            <string>SOS 循环次数</string>
            <key>default</key>
            <integer>3</integer>
            <key>min</key>
            <integer>1</integer>
            <key>max</key>
            <integer>20</integer>
            <key>minValue</key>
            <integer>1</integer>
            <key>maxValue</key>
            <integer>20</integer>
            <key>isSegmented</key>
            <false/>
            <key>showValue</key>
            <true/>
        </dict>
    </array>
</dict>
</plist>
