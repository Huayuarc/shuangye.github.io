#!/bin/bash

# CPUthermal postinst
# 安装/升级完成后重启 thermalmonitord 使 tweak 生效

case "$1" in
    configure)
        # 延迟 2 秒后重启 thermalmonitord，确保:
        # 1) thermalmonitord 完成基础初始化
        # 2) 各类 ObjC 热管理类已加载
        # 3) tweak 的延迟钩子安装（1 秒后）在安全时机执行
        nohup bash -c '
            sleep 2
            killall -q thermalmonitord 2>/dev/null || \
            /var/jb/usr/bin/killall -q thermalmonitord 2>/dev/null || \
            /usr/bin/killall -q thermalmonitord 2>/dev/null || true
        ' >/dev/null 2>&1 &
        ;;
    abort-upgrade|abort-remove|abort-deconfigure)
        ;;
esac

exit 0
