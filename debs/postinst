#!/bin/bash

# Jade Post-Installation Script

# Kill preferences cache to rescan preference bundles
if [[ -f /var/jb/usr/libexec/PlistBuddy ]]; then
    /var/jb/usr/bin/killall -9 cfprefsd 2>/dev/null || true
fi

# Reload preferences
if [[ -f /var/jb/usr/bin/killall ]]; then
    /var/jb/usr/bin/killall -9 Preferences 2>/dev/null || true
fi

exit 0
